{
  "name": "growthik_media",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "node --no-warnings ./node_modules/eslint/bin/eslint.js",
    "audit:crawl": "node automation/seo-audit/crawler.mjs",
    "audit:report": "node automation/seo-audit/generate-report.mjs",
