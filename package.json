    "@mui/lab": "^7.0.1-beta.20",
    "@mui/material": "^7.3.6",
    "@prisma/client": "^5.10.2",
    "aos": "^2.3.4",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^5.5.10",
    "framer-motion": "^12.38.0",
