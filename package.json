    "next": "^16.0.7",
    "next-themes": "^0.4.6",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.5",
    "prisma": "^5.10.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
